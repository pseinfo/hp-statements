{
  "name": "@pseinfo/hp-statements",
  "description": "GHS hazard and precautionary statements",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Paul Köhler",
    "email": "webmaster@komed3.de",
    "url": "https://komed3.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pseinfo/hp-statements.git"
  },
  "bugs": {
    "url": "https://github.com/pseinfo/hp-statements/issues"
  },
  "keywords": [
    "hp-statements",
    "hazard-statements",
    "precautionary-statements",
    "pseinfo"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "fetch": "npx tsx scripts/fetch.mts",
    "lint": "tsc --noEmit",
    "clean": "shx rm -rf dist",
    "tsc": "tsc --project tsconfig.build.json",
    "format": "prettier --write \"dist/**/*\" --ignore-path \"\" --log-level warn",
    "build": "npm run clean && npm run tsc && npm run format"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "json-stable-stringify": "^1.3.0",
    "prettier": "^3.8.3",
    "shx": "^0.4.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
