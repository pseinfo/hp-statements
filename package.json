{
  "name": "@pseinfo/hp-statements",
  "description": "GHS hazard and precautionary statements",
  "version": "1.1.0",
  "license": "MIT",
  "author": {
    "name": "Paul Köhler",
    "email": "webmaster@komed3.de",
    "url": "https://komed3.de"
  },
  "homepage": "https://pseinfo.github.io/hp-statements",
  "repository": {
    "type": "git",
    "url": "https://github.com/pseinfo/hp-statements.git"
  },
  "bugs": {
    "url": "https://github.com/pseinfo/hp-statements/issues"
  },
  "keywords": [
    "hp-statements",
    "hazard-statements",
    "precautionary-statements",
    "pseinfo"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./data/*": {
      "types": "./dist/data/*.d.ts",
      "import": "./dist/data/*.js",
      "default": "./dist/data/*.js"
    }
  },
  "scripts": {
    "fetch": "shx rm -rf data && npx tsx scripts/fetch.mts",
    "lint": "tsc --noEmit",
    "tsc": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "types": "tsc --project tsconfig.declaration.json && tsc-alias -p tsconfig.declaration.json",
    "format": "prettier --write \"dist/**/*\" --ignore-path \"\" --log-level warn",
    "build": "shx rm -rf dist && npm run tsc && npm run types && npm run format",
    "docs": "shx rm -rf dist/docs && npx tsx scripts/docs.mts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "json-stable-stringify": "^1.3.0",
    "prettier": "^3.8.3",
    "shx": "^0.4.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
