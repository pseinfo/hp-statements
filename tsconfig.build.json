{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "removeComments": true,
    "declaration": false
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  },
  "include": [ "data/**/*.ts", "data/**/*.json", "src/**/*.ts" ],
  "exclude": [ "node_modules", "scripts" ]
}
